import { GatewayClient } from "@circle-fin/x402-batching/client";

async function main() {
  const client = new GatewayClient({
    chain: "arcTestnet",
    privateKey: process.env.BUYER_WALLET_KEY as `0x${string}`,
  });
  const { data, status } = await client.pay("http://localhost:3001/api/crypto/BTC/signals");
  console.log("Status:", status);
  console.log("Data:", data);
}

main().catch(console.error);
